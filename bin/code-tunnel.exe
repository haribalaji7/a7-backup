#!/usr/bin/env node
/**
 * Port forwarding wrapper for Antigravity
 * Uses localtunnel to provide public URLs for localhost
 * 
 * Usage: code-tunnel.exe tunnel --port 3000
 */

const localtunnel = require('localtunnel');

// Parse arguments
const args = process.argv.slice(2);
let port = 3000;

// Find --port argument
for (let i = 0; i < args.length; i++) {
  if ((args[i] === '--port' || args[i] === '-p') && args[i + 1]) {
    port = parseInt(args[i + 1]);
    break;
  }
  if (args[i].startsWith('--port=')) {
    port = parseInt(args[i].split('=')[1]);
    break;
  }
}

// Check if this is a tunnel command
if (args[0] === 'tunnel' || args.length === 0) {
  console.log(`Creating tunnel for localhost:${port}...`);
  
  (async () => {
    try {
      const tunnel = await localtunnel({ port });
      
      console.log('');
      console.log('Port forwarding is now active!');
      console.log(`Local:    http://localhost:${port}`);
      console.log(`Public:   ${tunnel.url}`);
      console.log('');
      console.log('Press Ctrl+C to stop.');
      
      tunnel.on('close', () => {
        process.exit(0);
      });
      
      tunnel.on('error', (err) => {
        console.error('Tunnel error:', err.message);
        process.exit(1);
      });
      
      // Keep process alive
      setInterval(() => {}, 1000);
      
    } catch (err) {
      console.error('Failed to create tunnel:', err.message);
      process.exit(1);
    }
  })();
} else if (args[0] === '--version' || args[0] === '-v') {
  console.log('Tunnel CLI 1.0.0 (localtunnel wrapper)');
} else if (args[0] === '--help' || args[0] === '-h') {
  console.log('Usage: code-tunnel tunnel --port <port>');
  console.log('');
  console.log('Options:');
  console.log('  --port <number>  Local port to forward (default: 3000)');
  console.log('  --version        Show version');
  console.log('  --help           Show help');
} else {
  console.error('Unknown command:', args[0]);
  process.exit(1);
}
